package testng;

import io.github.bonigarcia.wdm.WebDriverManager;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.testng.annotations.Test;

import java.time.Duration;
import java.util.List;

public class test {

    @Test
    public void getScorecardAndTopScorer() {
        WebDriverManager.chromedriver().setup();
        WebDriver driver = new ChromeDriver();
        WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(20));

        try {
            driver.get("https://www.cricbuzz.com/cricket-match/live-scores");

            // Navigate to the PAK vs NAM match
            WebElement match = wait.until(ExpectedConditions.elementToBeClickable(By.xpath("//a[contains(@title, 'Pakistan vs Namibia')]")));
            match.click();

            // Click Scorecard Tab
            WebElement scorecardTab = wait.until(ExpectedConditions.elementToBeClickable(By.xpath("//a[text()='Scorecard']")));
            scorecardTab.click();

            // Find all rows in the first innings
            List<WebElement> rows = driver.findElements(By.xpath("//div[@id='innings_1']//div[contains(@class,'cb-scrd-itms')]"));

            String highestScorer = "";
            int maxRuns = -1;

            System.out.println(String.format("%-20s %-30s %-5s", "Batsman", "Dismissal", "Runs"));
            System.out.println("---------------------------------------------------------------");

            for (WebElement row : rows) {
                List<WebElement> cols = row.findElements(By.cssSelector("div"));
                
                // A valid batsman row in Cricbuzz has at least 3-7 columns
                if (cols.size() > 3) {
                    String name = cols.get(0).getText().trim();
                    String dismissal = cols.get(1).getText().trim();
                    String runsText = cols.get(2).getText().trim();

                    // Print each row for the full scorecard view
                    if (!name.isEmpty() && !name.equalsIgnoreCase("Extras") && !name.equalsIgnoreCase("Total")) {
                        System.out.println(String.format("%-20s %-30s %-5s", name, dismissal, runsText));

                        // Logical check for highest scorer
                        try {
                            int runs = Integer.parseInt(runsText);
                            if (runs > maxRuns) {
                                maxRuns = runs;
                                highestScorer = name;
                            }
                        } catch (NumberFormatException e) {
                            // Skip if runs column is not a number (e.g., "DNB")
                        }
                    }
                }
            }

            System.out.println("---------------------------------------------------------------");
            System.out.println("Highest Scorer: " + highestScorer + " (" + maxRuns + " runs)");

        } finally {
            driver.quit();
        }
    }
}