package testng;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.ui.Select;

public class AmazonTest {
    WebDriver driver;

    // Locators
    By accountList = By.id("nav-link-accountList");
    By emailField = By.id("ap_email");
    By continueBtn = By.id("continue");
    By passwordField = By.id("ap_password");
    By signInBtn = By.id("signInSubmit");
    By categoryDropDown = By.id("searchDropdownBox");
    By searchBox = By.id("twotabsearchtextbox");
    By searchSubmit = By.id("nav-search-submit-button");
    By firstProduct = By.xpath("(//div[@class='sg-col-inner']//h2/a)[1]");
    By addToCartBtn = By.id("add-to-cart-button");
    By proceedToCheckout = By.name("proceedToCheckout");
    By signOutLink = By.id("nav-item-signout");

    public AmazonTest(WebDriver driver) {
        this.driver = driver;
    }

    public void login(String email, String pass) {
        driver.findElement(accountList).click();
        driver.findElement(emailField).sendKeys(email);
        driver.findElement(continueBtn).click();
        driver.findElement(passwordField).sendKeys(pass);
        driver.findElement(signInBtn).click();
    }

    public void selectCategory(String category) {
        Select sel = new Select(driver.findElement(categoryDropDown));
        sel.selectByVisibleText(category);
    }

    public void searchProduct(String productName) {
        driver.findElement(searchBox).sendKeys(productName);
        driver.findElement(searchSubmit).click();
    }

    public void addToCart() {
        driver.findElement(firstProduct).click();
        // Switch to new tab if Amazon opens product in new window
        for (String handle : driver.getWindowHandles()) {
            driver.switchTo().window(handle);
        }
        driver.findElement(addToCartBtn).click();
    }

    public void checkout() {
        driver.findElement(proceedToCheckout).click();
    }

    public void logout() {
        // Amazon requires hovering over 'Account & Lists' to see Sign Out
        // For simplicity, we can navigate directly to the logout URL or use Actions class
        driver.findElement(accountList).click(); // Navigate to account page
        driver.findElement(signOutLink).click();
    }
}