package testng;

import java.time.Duration;
import java.util.Set;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.Select;

import org.testng.annotations.*;
import io.github.bonigarcia.wdm.WebDriverManager;

public class AmazonTest {

    WebDriver driver;
    WebDriverWait wait;

    @BeforeClass
    public void setup() {

        WebDriverManager.chromedriver().setup();
        driver = new ChromeDriver();
        driver.manage().window().maximize();

        wait = new WebDriverWait(driver, Duration.ofSeconds(30));

        driver.get("https://www.amazon.in/");
    }

    @Test(priority = 1)
    public void login() {

        // Click Sign In
        wait.until(ExpectedConditions.elementToBeClickable(By.id("nav-link-accountList"))).click();

        // Enter Email
        WebElement emailField = wait.until(
                ExpectedConditions.visibilityOfElementLocated(By.id("ap_email")));
        emailField.clear();
        emailField.sendKeys("himanshuraj.01@outlook.com");

        driver.findElement(By.id("continue")).click();

        // Enter Password
        WebElement passwordField = wait.until(
                ExpectedConditions.visibilityOfElementLocated(By.id("ap_password")));
        passwordField.clear();
        passwordField.sendKeys("Q1w2e3r4t5()");

        driver.findElement(By.id("signInSubmit")).click();

        // Wait until homepage loads (VERY IMPORTANT)
        wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("nav-logo-sprites")));
    }

    @Test(priority = 2)
    public void selectCategoryAndSearch() {

        // Select category using Select class (Correct way)
        WebElement dropdown = wait.until(
                ExpectedConditions.elementToBeClickable(By.id("searchDropdownBox")));

        Select select = new Select(dropdown);
        select.selectByVisibleText("Electronics");

        // Search product
        WebElement searchBox = wait.until(
                ExpectedConditions.visibilityOfElementLocated(By.id("twotabsearchtextbox")));

        searchBox.clear();
        searchBox.sendKeys("Laptop");

        driver.findElement(By.id("nav-search-submit-button")).click();

        // Wait for results
        wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.cssSelector("div.s-main-slot")));
    }

    @Test(priority = 3)
    public void addToCart() {

        // Click first product
        WebElement firstProduct = wait.until(
                ExpectedConditions.elementToBeClickable(
                        By.cssSelector("div.s-main-slot div[data-component-type='s-search-result'] h2 a")));

        firstProduct.click();

        // Switch to new tab
        String mainWindow = driver.getWindowHandle();
        Set<String> allWindows = driver.getWindowHandles();

        for (String window : allWindows) {
            if (!window.equals(mainWindow)) {
                driver.switchTo().window(window);
                break;
            }
        }

        // Add to cart
        wait.until(ExpectedConditions.elementToBeClickable(
                By.id("add-to-cart-button"))).click();
    }

    @Test(priority = 4)
    public void checkout() {

        wait.until(ExpectedConditions.elementToBeClickable(
                By.name("proceedToRetailCheckout"))).click();
    }

    @Test(priority = 5)
    public void logout() {

        driver.get("https://www.amazon.in/gp/flex/sign-out.html");

        wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("nav-logo-sprites")));
    }

    @AfterClass
    public void tearDown() {

        if (driver != null) {
            driver.quit();
        }
    }
}
